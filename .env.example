# Food Delivery Platform - Environment Configuration
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env

# ===================
# PostgreSQL Configuration
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===================
# Database password alias (used by services)
# ===================
DB_PASSWORD=postgres

# ===================
# RabbitMQ Configuration
# ===================
RABBIT_USER=guest
RABBIT_PASSWORD=guest

# ===================
# JWT Configuration
# ===================
# Must be at least 32 characters for HMAC-SHA256
# In production, use a 64+ character random string
JWT_SECRET=changeme_supersecretkey_minimum32chars