# Food Delivery Platform - Environment Configuration
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env

# ===================
# PostgreSQL Configuration
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===================
# Database password alias (used by services)
# ===================
DB_PASSWORD=postgres

# ===================
# RabbitMQ Configuration
# ===================
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_MGMT_PORT=15672

# ===================
# JWT Configuration
# ===================
# Must be at least 32 characters for HMAC-SHA256
# In production, use a 64+ character random string
JWT_SECRET=changeme_supersecretkey_minimum32chars

# ===================
# Service Discovery (Eureka)
# ===================
EUREKA_HOST=localhost
EUREKA_PORT=8761

# ===================
# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================
# Service Ports (used by application.yml)
# ===================
GATEWAY_PORT=8080
CUSTOMER_PORT=8081
RESTAURANT_PORT=8082
ORDER_PORT=8083
DELIVERY_PORT=8084
# EUREKA_PORT is already defined in the Service Discovery section above (value: 8761)
# It is used both for the Eureka server itself and for clients connecting to it.